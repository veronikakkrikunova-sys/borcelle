# Resend (https://resend.com) API key used by app/api/contact/route.ts to send
# contact-form submissions by email. Sign up, verify a sending domain (or use
# the resend.dev testing domain), create an API key, then copy this file to
# .env.local and fill in the values below.
RESEND_API_KEY=

# Email address the "From" header will use. Must be on a domain you've
# verified in Resend (or onboarding@resend.dev for testing).
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Where contact-form submissions should be delivered.
CONTACT_TO_EMAIL=hello@borcelle.ca
